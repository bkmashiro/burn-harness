{
  "name": "burn-harness",
  "version": "0.1.1",
  "description": "AI coding CLI orchestrator — run Claude/Codex/Aider non-stop on a dev task queue",
  "type": "module",
  "bin": {
    "burn": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "claude",
    "codex",
    "aider",
    "automation",
    "coding",
    "cli",
    "agent"
  ],
  "author": "yuzhe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bkmashiro/burn-harness.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "minimatch": "^10.2.5",
    "ora": "^9.3.0",
    "pino": "^10.3.1",
    "strip-ansi": "^7.2.0",
    "ulid": "^3.0.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
